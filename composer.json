{
    "name": "php-soap/psr18-transport",
    "description": "PSR-18 HTTP Client transport for SOAP",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Soap\\Psr18Transport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SoapTest\\Psr18Transport\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Toon Verwerft",
            "email": "toonverwerft@gmail.com"
        }
    ],
    "require": {
        "php": "~8.3.0 || ~8.4.0 || ~8.5.0",
        "ext-dom": "*",
        "php-soap/engine": "^2.16",
        "php-soap/wsdl": "^1.14",
        "php-soap/xml": "^1.9",
        "php-http/discovery": "^1.12",
        "psr/http-client-implementation": "^1.0",
        "psr/http-factory-implementation": "^1.0",
        "psr/http-message-implementation": "^1.0",
        "psr/http-message": "^1.0.1|^2.0",
        "veewee/xml": "^3.7",
        "php-http/client-common": "^2.3"
    },
    "require-dev": {
        "ext-soap": "*",
        "nyholm/psr7": "^1.5",
        "php-http/mock-client": "^1.5",
        "php-soap/ext-soap-engine": "^1.7",
        "php-soap/engine-integration-tests": "^1.10",
        "phpunit/phpunit": "~12.3",
        "vimeo/psalm": "~6.13",
        "php-cs-fixer/shim": "~3.88",
        "guzzlehttp/guzzle": "^7.5"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
